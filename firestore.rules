rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'aryafian232@gmail.com';
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      // Only booking owner or admin can read (privacy protection)
      allow read: if request.auth != null && 
                    (request.auth.uid == resource.data.bookedByUid || isAdmin());
      // Authenticated users can create
      allow create: if request.auth != null;
      // Backend-only status updates via Midtrans webhook
      allow update: if false;
      // Users can delete own bookings (e.g., for error recovery or cancellation)
      allow delete: if request.auth != null && request.auth.uid == resource.data.bookedByUid;
    }
    
    // News collection - admin can manage, everyone can read
    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Schedules collection - admin can manage, everyone can read
    match /schedules/{scheduleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Backgrounds collection - admin can manage, everyone can read
    match /backgrounds/{backgroundId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Settings collection - admin can manage, everyone can read
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Block all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
